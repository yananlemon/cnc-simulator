{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CNC Simulator",
  "version": "0.1.0",
  "identifier": "com.cnc.simulator",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1422",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1422",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CNC Simulator",
        "width": 1600,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
